DATABASE_PATH=data/request-manager.db
UPLOADS_PATH=data/uploads
TEMP_UPLOADS_PATH=data/tmp
BACKUP_PATH=data/backups
APP_ORIGIN=http://localhost:3000
SECURE_COOKIES=false
TRUST_PROXY_HEADERS=false

# Used only by the one-time first-developer command.
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=Administrator
ADMIN_PASSWORD=

# Destructive seed paths are accepted only with NODE_ENV=test and must differ
# from DATABASE_PATH and UPLOADS_PATH.
E2E_DATABASE_PATH=data/e2e/request-manager.db
E2E_UPLOADS_PATH=data/e2e/uploads
E2E_PASSWORD=e2e secure password
