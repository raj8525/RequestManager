{
  "name": "request-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "e2e:server": "tsx scripts/e2e-server.ts",
    "db:generate": "drizzle-kit generate --name=initial",
    "db:migrate": "tsx scripts/migrate.ts",
    "admin:init": "tsx scripts/init-developer.ts",
    "ops:backup": "tsx scripts/backup.ts",
    "ops:restore": "tsx scripts/restore.ts",
    "ops:attachments:check": "tsx scripts/check-attachments.ts",
    "ops:attachments:repair": "tsx scripts/check-attachments.ts --apply",
    "e2e:seed": "tsx scripts/e2e-seed.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "file-type": "^22.0.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.16"
  }
}
